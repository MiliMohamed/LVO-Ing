# Copier vers backend/.env (non versionné) :  copy backend\.env.example backend\.env
# Ne jamais committer backend/.env (contient AZURE_CLIENT_SECRET).
#
# OneDrive = Microsoft 365 (pas Google Drive). Prérequis Azure AD :
#   1. Portail Azure → Inscriptions d'applications → Nouvelle inscription (compte uniquement org.)
#   2. Certificats et secrets → Nouveau secret client → copier dans AZURE_CLIENT_SECRET
#   3. Autorisations API → Microsoft Graph → Application :
#        Files.ReadWrite.All  (+ consentement administrateur)
#   4. Renseigner tenant-id, client-id, secret ci-dessous

# Activer la création d'arborescence à chaque POST /api/sites
ONEDRIVE_ENABLED=true

# Application Azure AD
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=votre-secret-client

# Compte Microsoft 365 dont le OneDrive recevra Sites/[Nom du site]/...
ONEDRIVE_USER_EMAIL=documents@lvo.fr

# Optionnel : ID Graph du dossier Sites s'il existe déjà (sinon créé automatiquement)
# ONEDRIVE_SITES_ROOT_FOLDER_ID=
