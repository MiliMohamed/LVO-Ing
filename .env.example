# Prisma (racine)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/lvo_crm?schema=public"

# API Express (dossier server/) — Phase 3
API_PORT=8080
JWT_SECRET=changez-moi-en-production
# Optionnel : si défini, POST /api/webhooks/quonto exige x-qonto-signature (HMAC-SHA256 du corps brut)
QUONTO_WEBHOOK_SECRET=

# Frontend (frontend/.env.local) — pointer vers l’API
NEXT_PUBLIC_API_URL=http://localhost:8080

# Backend Spring (backend/.env) — arborescence OneDrive à la création de site
# Voir backend/.env.example pour le détail (AZURE_*, ONEDRIVE_*).
